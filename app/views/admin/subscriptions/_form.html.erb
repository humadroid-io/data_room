<%= form_with model: subscription, url: subscription.persisted? ? admin_subscription_path(subscription) : admin_subscriptions_path, class: "space-y-4 card bg-base-100 border border-base-300 p-6" do |f| %>
  <% if subscription.errors.any? %>
    <div class="alert alert-error text-sm">
      <ul class="list-disc pl-4">
        <% subscription.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Customer</label>
      <%= f.collection_select :customer_id, Customer.order(:name), :id, :name,
            { include_blank: "—" }, class: "select select-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Stripe price ID</label>
      <%= f.text_field :stripe_price_id, placeholder: "price_…", class: "input input-bordered w-full font-mono text-sm" %>
      <p class="text-xs text-base-content/50 mt-1">Raw Stripe price ID. Optional for manual entries.</p>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Product code <span class="text-base-content/40 normal-case">(optional)</span></label>
      <%= f.text_field :product_code, class: "input input-bordered w-full font-mono text-sm" %>
      <p class="text-xs text-base-content/50 mt-1">Friendly name. Auto-filled from the YAML mapping when synced.</p>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Stripe customer ID</label>
      <%= f.text_field :stripe_customer_id, class: "input input-bordered w-full font-mono text-sm" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Stripe subscription ID</label>
      <%= f.text_field :stripe_subscription_id, class: "input input-bordered w-full font-mono text-sm" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">MRR (cents)</label>
      <%= f.number_field :mrr_cents, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Currency</label>
      <%= f.text_field :currency, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Status</label>
      <%= f.select :status, Subscription.statuses.keys.map { |k| [k.titleize, k] },
            {}, class: "select select-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Started at</label>
      <%= f.datetime_local_field :started_at, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Canceled at</label>
      <%= f.datetime_local_field :canceled_at, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Paused at</label>
      <%= f.datetime_local_field :paused_at, class: "input input-bordered w-full" %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.submit (subscription.persisted? ? "Save" : "Create"), class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_subscriptions_path, class: "btn btn-ghost" %>
  </div>
<% end %>
