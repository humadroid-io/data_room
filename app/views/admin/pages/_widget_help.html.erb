<%
  groups = [
    [ "Navigation", [
      [ "[CHILD_PAGES]",       "1-column list of visible child pages" ],
      [ "[CHILD_PAGES_2_COL]", "2-column grid of visible child pages" ]
    ] ],
    [ "Customers & pipeline", [
      [ "[CUSTOMER_PIPELINE:attribute_key]", "customers grouped by a single-select attribute" ],
      [ "[RETENTION_COHORT:attribute_key]",  "stage progression over time" ],
      [ "[CUSTOMER_CONCENTRATION]",          "top 10 customers by active MRR" ]
    ] ],
    [ "Revenue", [
      [ "[MONTHLY_REVENUE]", "cash collected per month, with event annotations" ],
      [ "[MRR_WALK]",        "new + expansion vs contraction + churn" ],
      [ "[NRR_GRR]",         "net + gross revenue retention" ],
      [ "[QUICK_RATIO]",     "gain ÷ loss (≥4 healthy)" ]
    ] ],
    [ "Churn & retention", [
      [ "[CHURN_RATE]",        "monthly logo-churn %" ],
      [ "[CHURN_REASONS]",     "categorized why-they-left bar chart" ],
      [ "[CHURNED_CUSTOMERS]", "chronological churn log" ],
      [ "[COHORT_RETENTION]",  "classical % retained per acquisition cohort" ]
    ] ]
  ]
%>

<div class="space-y-5 text-xs">
  <% groups.each do |label, tokens| %>
    <section>
      <h3 class="uppercase tracking-wide text-[10px] text-base-content/50 mb-2"><%= label %></h3>
      <dl class="grid grid-cols-1 sm:grid-cols-[max-content_1fr] gap-x-3 gap-y-1.5">
        <% tokens.each do |token, description| %>
          <dt class="font-mono text-base-content/80">
            <code class="bg-base-200 px-1.5 py-0.5 rounded whitespace-nowrap"><%= token %></code>
          </dt>
          <dd class="text-base-content/60 self-center"><%= description %></dd>
        <% end %>
      </dl>
    </section>
  <% end %>
</div>
