<% content_for :title, "Payment #{@payment.stripe_invoice_id}" %>
<% content_for :page_title, payment_amount(@payment) %>
<% content_for :page_subtitle do %>
  Paid <%= @payment.paid_at.to_fs(:long) %> by
  <%= link_to @payment.customer.name, admin_customer_path(@payment.customer), class: "underline" %>
<% end %>

<div class="card bg-base-100 border border-base-300 p-6 space-y-4">
  <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Amount (USD)</dt>
      <dd class="mt-1 text-lg font-semibold tabular-nums"><%= payment_amount(@payment) %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Native amount</dt>
      <dd class="mt-1 tabular-nums">
        <%= payment_native_amount(@payment) %>
        <span class="text-xs text-base-content/60 uppercase"><%= @payment.currency %></span>
      </dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Paid at</dt>
      <dd class="mt-1"><%= @payment.paid_at.strftime("%Y-%m-%d %H:%M") %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Customer</dt>
      <dd class="mt-1"><%= link_to @payment.customer.name, admin_customer_path(@payment.customer), class: "underline" %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Subscription</dt>
      <dd class="mt-1">
        <% if @payment.subscription %>
          <%= link_to @payment.subscription.display_product, admin_subscription_path(@payment.subscription), class: "underline" %>
        <% else %>
          <span class="text-base-content/40 italic">one-off (no subscription)</span>
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Stripe invoice ID</dt>
      <dd class="mt-1"><code class="text-xs"><%= @payment.stripe_invoice_id %></code></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-base-content/50">Stripe charge ID</dt>
      <dd class="mt-1"><code class="text-xs"><%= @payment.stripe_charge_id || "—" %></code></dd>
    </div>
  </dl>
</div>

<p class="mt-4 text-xs text-base-content/50">
  Payments are imported by <code>StripeSyncJob</code> and read-only here —
  edit the underlying invoice in your Stripe dashboard if anything looks wrong.
</p>
