<%= form_with model: customer, url: customer.persisted? ? admin_customer_path(customer) : admin_customers_path, class: "space-y-6" do |f| %>
  <% if customer.errors.any? %>
    <div class="alert alert-error text-sm">
      <ul class="list-disc pl-4">
        <% customer.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="card bg-base-100 border border-base-300 p-6 space-y-4">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-base-content/60">Profile</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="label label-text text-xs uppercase tracking-wide">Name</label>
        <%= f.text_field :name, class: "input input-bordered w-full" %>
      </div>
      <div>
        <label class="label label-text text-xs uppercase tracking-wide">Anonymized label</label>
        <%= f.text_field :anonymized_label, class: "input input-bordered w-full",
              placeholder: "e.g. AI SaaS, 12 employees" %>
      </div>
    </div>

    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Stripe customer ID</label>
      <%= f.text_field :stripe_customer_id, class: "input input-bordered w-full font-mono text-sm",
            placeholder: "cus_..." %>
    </div>

    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Notes</label>
      <%= f.text_area :notes, rows: 3, class: "textarea textarea-bordered w-full" %>
    </div>

    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :reference_call_ok, class: "checkbox checkbox-sm" %>
      <span class="text-sm">Available for reference calls</span>
    </label>
  </div>

  <% defns = AttributeDefinition.for_resource(Customer) %>
  <% if defns.any? %>
    <div class="card bg-base-100 border border-base-300 p-6 space-y-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-base-content/60">Custom attributes</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% defns.each do |defn| %>
          <% next if defn.boolean? %>
          <div>
            <label class="label label-text text-xs uppercase tracking-wide">
              <%= defn.label %><%= " *" if defn.required? %>
            </label>
            <%= custom_attribute_field(f, defn, customer.custom_attribute(defn.key)) %>
            <% if defn.description.present? %>
              <p class="text-xs text-base-content/50 mt-1"><%= defn.description %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <% boolean_defns = defns.select(&:boolean?) %>
      <% if boolean_defns.any? %>
        <div class="space-y-2 pt-2">
          <% boolean_defns.each do |defn| %>
            <%= custom_attribute_field(f, defn, customer.custom_attribute(defn.key)) %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="card bg-base-100 border border-base-300 p-6 space-y-4">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-base-content/60">Churn</h2>
    <p class="text-xs text-base-content/50">
      Leave the date blank for active customers. <strong>Auto-set</strong> when every Stripe
      subscription is canceled — a manual value won't be overwritten by sync.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="label label-text text-xs uppercase tracking-wide">Churned on</label>
        <%= f.date_field :churned_on, class: "input input-bordered w-full" %>
      </div>
      <div>
        <label class="label label-text text-xs uppercase tracking-wide">Reason category</label>
        <%= f.select :churn_reason_category,
              Customer.churn_reason_categories.keys.map { |k| [ k.titleize, k ] },
              { include_blank: "—" },
              class: "select select-bordered w-full" %>
      </div>
    </div>

    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Reason notes <span class="text-base-content/40 normal-case">(optional, anonymized text shown to investors)</span></label>
      <%= f.text_area :churn_reason_notes, rows: 3, class: "textarea textarea-bordered w-full",
            placeholder: "Anything you'd be comfortable letting an investor read." %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.submit (customer.persisted? ? "Save changes" : "Create customer"), class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_customers_path, class: "btn btn-ghost" %>
  </div>
<% end %>
