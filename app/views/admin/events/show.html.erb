<% content_for :title, @event.title %>
<% content_for :page_title, @event.title %>
<% content_for :page_subtitle do %>
  <%= @event.occurred_on.to_fs(:long) %> · <%= event_kind_badge(@event) %>
<% end %>
<% content_for :page_header do %>
  <%= link_to "Edit", edit_admin_event_path(@event), class: "btn btn-primary btn-sm" %>
  <%= button_to "Delete", admin_event_path(@event), method: :delete,
        form: { class: "inline", data: { turbo_confirm: "Delete event?" } },
        class: "btn btn-ghost btn-sm text-error" %>
<% end %>

<div class="card bg-base-100 border border-base-300 p-6 space-y-4">
  <div class="flex items-center gap-3">
    <span class="inline-block w-3 h-3 rounded-full" style="background-color: <%= @event.color %>"></span>
    <span class="text-sm text-base-content/60">
      Marker color used on the <code>[MONTHLY_REVENUE]</code> chart, anchored to
      <code><%= @event.month_bucket %></code> on the x-axis.
    </span>
  </div>

  <% if @event.description.present? %>
    <div class="pt-4 border-t border-base-300">
      <dt class="text-xs uppercase tracking-wide text-base-content/50 mb-1">Description</dt>
      <dd class="text-sm whitespace-pre-wrap"><%= @event.description %></dd>
    </div>
  <% else %>
    <p class="text-sm text-base-content/60">No description recorded.</p>
  <% end %>
</div>
