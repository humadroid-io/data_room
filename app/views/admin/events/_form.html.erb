<%= form_with model: event,
      url: event.persisted? ? admin_event_path(event) : admin_events_path,
      class: "space-y-4 card bg-base-100 border border-base-300 p-6" do |f| %>
  <% if event.errors.any? %>
    <div class="alert alert-error text-sm">
      <ul class="list-disc pl-4">
        <% event.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Date</label>
      <%= f.date_field :occurred_on, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Kind</label>
      <%= f.select :kind,
            Event.kinds.keys.map { |k| [ k.titleize, k ] },
            {}, class: "select select-bordered w-full" %>
    </div>
  </div>

  <div>
    <label class="label label-text text-xs uppercase tracking-wide">Title</label>
    <%= f.text_field :title, class: "input input-bordered w-full",
          placeholder: "Series A — $5M from VastFund" %>
    <p class="text-xs text-base-content/50 mt-1">Shown as the marker label on the chart. Keep it short.</p>
  </div>

  <div>
    <label class="label label-text text-xs uppercase tracking-wide">Description</label>
    <%= f.text_area :description, rows: 3, class: "textarea textarea-bordered w-full",
          placeholder: "Optional context: who, why, dollars, links." %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.submit (event.persisted? ? "Save" : "Create"), class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_events_path, class: "btn btn-ghost" %>
  </div>
<% end %>
