<%= form_with model: user, url: user.persisted? ? admin_user_path(user) : admin_users_path,
      class: "space-y-4 card bg-base-100 border border-base-300 p-6" do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-error text-sm">
      <ul class="list-disc pl-4">
        <% user.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Name</label>
      <%= f.text_field :name, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Email</label>
      <%= f.email_field :email, class: "input input-bordered w-full", autocomplete: "off" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Role</label>
      <%= f.select :role,
               User.roles.keys.map { |r| [r.titleize, r] },
               {},
               class: "select select-bordered w-full",
               disabled: user == current_admin %>
      <% if user == current_admin %>
        <p class="text-xs text-base-content/50 mt-1">You can't change your own role.</p>
      <% end %>
    </div>
    <div></div>

    <div>
      <label class="label label-text text-xs uppercase tracking-wide">
        Password<%= " (leave blank to keep)" if user.persisted? %>
      </label>
      <%= f.password_field :password,
                       class: "input input-bordered w-full",
                       autocomplete: "new-password" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Confirm password</label>
      <%= f.password_field :password_confirmation,
                       class: "input input-bordered w-full",
                       autocomplete: "new-password" %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.submit (user.persisted? ? "Save" : "Create"), class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_users_path, class: "btn btn-ghost" %>
  </div>
<% end %>
