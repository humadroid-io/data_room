<%= form_with model: investor, url: investor.persisted? ? admin_investor_path(investor) : admin_investors_path, class: "space-y-4 card bg-base-100 border border-base-300 p-6" do |f| %>
  <% if investor.errors.any? %>
    <div class="alert alert-error text-sm">
      <ul class="list-disc pl-4">
        <% investor.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Name</label>
      <%= f.text_field :name, class: "input input-bordered w-full" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Fund</label>
      <%= f.text_field :fund_name, class: "input input-bordered w-full" %>
    </div>
    <div class="md:col-span-2">
      <label class="label label-text text-xs uppercase tracking-wide">Email <span class="text-base-content/40 normal-case">(optional, for records)</span></label>
      <%= f.email_field :email, class: "input input-bordered w-full" %>
    </div>
    <div class="md:col-span-2">
      <label class="label label-text text-xs uppercase tracking-wide">Watermark label</label>
      <%= f.text_field :watermark_label, class: "input input-bordered w-full",
            placeholder: "Defaults to name + fund" %>
    </div>
    <div>
      <label class="label label-text text-xs uppercase tracking-wide">Access expires at</label>
      <%= f.datetime_local_field :access_expires_at, class: "input input-bordered w-full" %>
    </div>
    <div class="flex items-end">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.check_box :active, class: "checkbox checkbox-sm" %>
        <span class="text-sm">Active</span>
      </label>
    </div>
  </div>

  <div class="pt-4 border-t border-base-300 space-y-2">
    <label class="label label-text text-xs uppercase tracking-wide">Access code</label>
    <%= f.text_field :access_code, class: "input input-bordered w-full font-mono",
          placeholder: "Auto-generated on save if blank",
          autocomplete: "off", spellcheck: false %>
    <p class="text-xs text-base-content/50">
      The investor signs in with this code alone. Letters, digits, <code>_</code> and <code>-</code>, min 6 chars.
      <% if investor.persisted? && investor.access_code.present? %>
        Shareable link:
        <code class="bg-base-200 px-1 py-0.5 rounded"><%= login_url(code: investor.access_code) %></code>
      <% end %>
    </p>
  </div>

  <div class="flex items-center gap-2">
    <%= f.submit (investor.persisted? ? "Save" : "Create"), class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_investors_path, class: "btn btn-ghost" %>
    <% if investor.persisted? %>
      <span class="ml-auto"></span>
      <%= button_to "Regenerate access code",
            regenerate_access_code_admin_investor_path(investor),
            method: :post,
            form: { class: "inline", data: { turbo_confirm: "Regenerate? The old code stops working immediately." } },
            class: "btn btn-ghost btn-sm" %>
    <% end %>
  </div>
<% end %>
