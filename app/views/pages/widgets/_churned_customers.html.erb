<% rows = churned_customers_widget %>

<div class="my-6 not-prose">
  <% if rows.any? %>
    <div class="overflow-x-auto border border-base-300 rounded-md">
      <table class="table table-sm">
        <thead class="text-xs uppercase tracking-wide text-base-content/60">
          <tr>
            <th class="!py-2.5 !px-3">Churned</th>
            <th class="!py-2.5 !px-3">Customer</th>
            <th class="!py-2.5 !px-3">Reason</th>
            <th class="!py-2.5 !px-3">Notes</th>
          </tr>
        </thead>
        <tbody>
          <% rows.each do |row| %>
            <tr>
              <td class="whitespace-nowrap text-base-content/70 !py-2.5 !px-3"><%= row[:churned_on].to_fs(:long) %></td>
              <td class="font-medium !py-2.5 !px-3"><%= row[:label] %></td>
              <td class="!py-2.5 !px-3">
                <% if row[:category_text] %>
                  <span class="badge badge-soft badge-sm"><%= row[:category_text] %></span>
                <% else %>
                  <span class="text-base-content/40">—</span>
                <% end %>
              </td>
              <td class="text-sm text-base-content/70 !py-2.5 !px-3"><%= row[:notes] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-base-content/50">
      <%= rows.size %> churned customer<%= 's' unless rows.size == 1 %> documented.
    </p>
  <% else %>
    <p class="text-sm text-base-content/60">No churned customers documented yet.</p>
  <% end %>
</div>
