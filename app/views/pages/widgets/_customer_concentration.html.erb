<% w = customer_concentration_widget %>

<div class="my-6 not-prose">
  <% if w[:rows].any? %>
    <div class="overflow-x-auto border border-base-300 rounded-md">
      <table class="table table-sm">
        <thead class="text-xs uppercase tracking-wide text-base-content/60">
          <tr>
            <th>Customer</th>
            <th class="text-right">MRR</th>
            <th class="text-right">% of total</th>
            <th class="w-1/3">Share</th>
          </tr>
        </thead>
        <tbody>
          <% w[:rows].each do |row| %>
            <% over_threshold = row[:percentage] >= 25 %>
            <tr>
              <td class="font-medium"><%= row[:label] %></td>
              <td class="text-right tabular-nums">$<%= number_with_delimiter(row[:dollars]) %></td>
              <td class="text-right tabular-nums <%= 'text-error font-medium' if over_threshold %>">
                <%= row[:percentage] %>%
              </td>
              <td>
                <div class="h-2 bg-base-200 rounded">
                  <div class="h-2 rounded <%= over_threshold ? 'bg-error' : 'bg-base-content/60' %>"
                       style="width: <%= row[:percentage].clamp(0, 100) %>%"></div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-base-content/50">
      Top 10 customers ranked by active MRR (out of $<%= number_with_delimiter(w[:total_dollars]) %> total).
      Bars turn red when a single account is ≥25% of total — a concentration risk investors flag.
    </p>
  <% else %>
    <p class="text-sm text-base-content/60">No active subscriptions yet.</p>
  <% end %>
</div>
