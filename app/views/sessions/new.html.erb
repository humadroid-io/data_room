<% content_for :title, "Sign in" %>
<% content_for :heading, "Investor sign-in" %>
<% content_for :subheading, "Enter the access code provided to you." %>

<%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
  <div>
    <label class="label label-text text-xs uppercase tracking-wide">Access code</label>
    <%= f.text_field :access_code,
          value: params[:code],
          autofocus: true,
          autocomplete: "off",
          spellcheck: false,
          class: "input input-bordered w-full font-mono" %>
  </div>
  <%= f.submit "Continue", class: "btn btn-primary w-full" %>
<% end %>

<p class="text-xs text-center text-base-content/50 mt-6">
  Are you an admin? <%= link_to "Admin sign-in", admin_login_path, class: "underline" %>
</p>
