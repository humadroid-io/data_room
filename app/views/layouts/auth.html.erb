<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <title><%= content_for(:title) || "Data Room" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="min-h-screen bg-base-200 flex items-center justify-center px-4">
    <main class="w-full max-w-sm">
      <div class="text-center mb-8">
        <div class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-primary text-primary-content font-semibold">DR</div>
        <h1 class="mt-4 text-xl font-semibold tracking-tight"><%= content_for?(:heading) ? yield(:heading) : "Data Room" %></h1>
        <% if content_for?(:subheading) %>
          <p class="mt-1 text-sm text-base-content/60"><%= yield :subheading %></p>
        <% end %>
      </div>

      <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-6">
          <% flash.each do |type, msg| %>
            <div class="alert alert-<%= type == 'alert' ? 'error' : 'info' %> text-sm py-2 mb-4"><%= msg %></div>
          <% end %>
          <%= yield %>
        </div>
      </div>
    </main>
  </body>
</html>
